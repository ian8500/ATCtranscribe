APP_ENV=development
DATABASE_URL=sqlite+pysqlite:///./atc.db
SECRET_KEY=change-this-to-a-long-random-secret
SESSION_COOKIE_NAME=atc_session
ACCESS_TOKEN_EXPIRE_MINUTES=60
SECURE_COOKIES=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=200

WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LOCAL_ONLY=false

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_ATTEMPTS=10

DEV_EMAIL_CONSOLE=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@atc.local

# First-run admin creation. Prefer setting explicit credentials.
ATC_ADMIN_NAME=Admin
ATC_ADMIN_EMAIL=
ATC_ADMIN_PASSWORD=
# Local-only shortcut:
ATC_CREATE_DEV_ADMIN=false
