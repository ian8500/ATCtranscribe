APP_ENV=development
DATABASE_URL=sqlite+pysqlite:///./atc.db
SECRET_KEY=change-this-to-a-long-random-secret
SESSION_COOKIE_NAME=atc_session
ACCESS_TOKEN_EXPIRE_MINUTES=60
SECURE_COOKIES=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=200

WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LOCAL_ONLY=false
WHISPER_BEAM_SIZE=5
WHISPER_TEMPERATURE=0
WHISPER_NO_SPEECH_THRESHOLD=0.45
WHISPER_LOG_PROB_THRESHOLD=-0.8
WHISPER_COMPRESSION_RATIO_THRESHOLD=2.4
WHISPER_REPETITION_PENALTY=1.15
WHISPER_NO_REPEAT_NGRAM_SIZE=3
WHISPER_VAD_MIN_SILENCE_MS=500
WHISPER_VAD_SPEECH_PAD_MS=150
WHISPER_HALLUCINATION_SILENCE_THRESHOLD=1.0
WHISPER_HOTWORDS_ENABLED=false
WHISPER_FFMPEG_DENOISE=false

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_ATTEMPTS=10

DEV_EMAIL_CONSOLE=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@atc.local

# First-run admin creation. Prefer setting explicit credentials.
ATC_ADMIN_NAME=Admin
ATC_ADMIN_EMAIL=
ATC_ADMIN_PASSWORD=
# Local-only shortcut:
ATC_CREATE_DEV_ADMIN=false
